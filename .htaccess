<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Redirect /p/product-id to index.html?p=product-id
    RewriteRule ^p/([^/]+)$ index.html?p=$1 [L,QSA]
    
    # Optional: General SPA route
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule . /index.html [L]
</IfModule>
